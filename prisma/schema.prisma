generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                 @id @default(uuid())
  username            String
  emailHash           String                 @unique
  passwordHash        String
  createdAt           DateTime               @default(now())
  tokens              DeviceToken[]
  joinReqs            HouseholdJoinRequest[]
  memberships         HouseholdMember[]
  createdPlanned      HouseholdPlanned[]     @relation("UserCreatedPlanned")
  createdRecurring    HouseholdRecurring[]   @relation("UserCreatedRecurring")
  ledgerEntries       LedgerEntry[]          @relation("UserLedgerEntries")
  createdSavingsGoals SavingsGoal[]          @relation("UserCreatedSavingsGoals")
  savingsTxns         SavingsTxn[]           @relation("UserSavingsTxns")
}

model JobLock {
  name      String
  key       String
  createdAt DateTime @default(now())

  @@id([name, key])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Household {
  id            String                 @id @default(uuid())
  name          String
  currency      String                 @default("EUR")
  createdAt     DateTime               @default(now())
  invites       HouseholdInvite[]
  joinReqs      HouseholdJoinRequest[]
  members       HouseholdMember[]
  planned       HouseholdPlanned[]     @relation("HouseholdPlanned")
  recurring     HouseholdRecurring[]   @relation("HouseholdRecurring")
  ledgerEntries LedgerEntry[]          @relation("HouseholdLedgerEntries")
  savingsGoals  SavingsGoal[]          @relation("HouseholdSavingsGoals")
}

model HouseholdMember {
  householdId String
  userId      String
  role        HouseholdRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])

  @@id([householdId, userId])
  @@index([userId], map: "HouseholdMember_userId_fkey")
}

model HouseholdInvite {
  id              String                 @id @default(uuid())
  householdId     String
  codeHash        String
  expiresAt       DateTime
  maxUses         Int                    @default(10)
  uses            Int                    @default(0)
  requireApproval Boolean                @default(true)
  createdBy       String
  usedAt          DateTime?
  revokedAt       DateTime?
  household       Household              @relation(fields: [householdId], references: [id], onDelete: Cascade)
  joinRequests    HouseholdJoinRequest[] @relation("InviteJoinRequests")

  @@index([householdId])
}

model HouseholdJoinRequest {
  id          String          @id @default(uuid())
  householdId String
  userId      String
  inviteId    String
  status      JoinStatus      @default(PENDING)
  createdAt   DateTime        @default(now())
  decidedAt   DateTime?
  decidedBy   String?
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invite      HouseholdInvite @relation("InviteJoinRequests", fields: [inviteId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id])

  @@unique([householdId, userId, status])
  @@index([inviteId], map: "HouseholdJoinRequest_inviteId_fkey")
  @@index([userId], map: "HouseholdJoinRequest_userId_fkey")
}

model HouseholdPlanned {
  id            String    @id @default(uuid())
  householdId   String
  createdBy     String
  concept       String
  type          EntryType
  amount        Decimal   @db.Decimal(14, 2)
  dueDate       DateTime
  month         String?
  notes         String?
  category      String?
  settledAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accountType   MoneyType @default(CASH)
  createdByUser User      @relation("UserCreatedPlanned", fields: [createdBy], references: [id])
  household     Household @relation("HouseholdPlanned", fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, dueDate])
  @@index([householdId, settledAt])
  @@index([householdId, createdAt])
  @@index([householdId, accountType, dueDate])
  @@index([createdBy], map: "HouseholdPlanned_createdBy_fkey")
}

model HouseholdRecurring {
  id            String    @id @default(uuid())
  householdId   String
  createdBy     String
  active        Boolean   @default(true)
  concept       String
  type          EntryType
  amount        Decimal   @db.Decimal(14, 2)
  dayOfMonth    Int?
  rrule         String?
  notes         String?
  category      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accountType   MoneyType @default(CASH)
  createdByUser User      @relation("UserCreatedRecurring", fields: [createdBy], references: [id])
  household     Household @relation("HouseholdRecurring", fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, active, createdAt])
  @@index([householdId, accountType, active])
  @@index([createdBy], map: "HouseholdRecurring_createdBy_fkey")
}

model LedgerEntry {
  id          String    @id @default(uuid())
  householdId String
  userId      String
  type        EntryType
  amount      Decimal   @db.Decimal(14, 2)
  category    String?
  note        String?
  occursAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  accountType MoneyType @default(CASH)
  household   Household @relation("HouseholdLedgerEntries", fields: [householdId], references: [id], onDelete: Cascade)
  user        User      @relation("UserLedgerEntries", fields: [userId], references: [id])
  occursAtDay DateTime?
  recurringId String?
  plannedId   String?

  @@unique([recurringId, occursAtDay])
  @@unique([plannedId])
  @@index([householdId, occursAt])
  @@index([householdId, occursAtDay])
  @@index([recurringId, occursAtDay])
}

model SavingsGoal {
  id            String       @id @default(uuid())
  householdId   String
  name          String
  target        Decimal      @db.Decimal(14, 2)
  deadline      DateTime?
  createdAt     DateTime     @default(now())
  createdBy     String
  createdByUser User         @relation("UserCreatedSavingsGoals", fields: [createdBy], references: [id])
  household     Household    @relation("HouseholdSavingsGoals", fields: [householdId], references: [id], onDelete: Cascade)
  txns          SavingsTxn[] @relation("GoalTxns")

  @@index([householdId])
  @@index([createdBy], map: "SavingsGoal_createdBy_fkey")
}

model SavingsTxn {
  id        String         @id @default(uuid())
  goalId    String
  userId    String
  type      SavingsTxnType
  amount    Decimal        @db.Decimal(14, 2)
  note      String?
  occursAt  DateTime       @default(now())
  createdAt DateTime       @default(now())
  goal      SavingsGoal    @relation("GoalTxns", fields: [goalId], references: [id], onDelete: Cascade)
  user      User           @relation("UserSavingsTxns", fields: [userId], references: [id])

  @@index([goalId, occursAt])
  @@index([userId], map: "SavingsTxn_userId_fkey")
}

enum HouseholdRole {
  OWNER
  ADMIN
  MEMBER
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EntryType {
  INCOME
  EXPENSE
}

enum SavingsTxnType {
  DEPOSIT
  WITHDRAW
}

enum MoneyType {
  CASH
  CARD
  BANK
}
